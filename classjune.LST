SQL> SELECT SAL , CASE
  2  WHEN SAL BETWEEN 800 AND 1500 THEN 'LOW'
  3  WHEN SAL BETWEEN 1500 AND 3000 THEN 'MID'
  4  WHEN SAL BETWEEN 3001 AND 5000 THEN 'HIGH'
  5  END AS TYPE_OF_SAL
  6  FROM EMP
  7  ORDER BY SAL;

