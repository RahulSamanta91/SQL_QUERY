SQL> SELECT COUNT(CASE WHEN SAL BETWEEN 800 AND 1500 THEN 1 END) AS LOW,
  2         COUNT(CASE WHEN SAL BETWEEN 1501 AND 3000 THEN 1 END) AS MID,
  3         COUNT(CASE WHEN SAL BETWEEN 3001 AND 5000 THEN 1 END) AS HIGH
  4  FROM EMP;

