SQL> SELECT CASE
  2           WHEN SAL BETWEEN 800 AND 1500 THEN 'LOW'
  3           WHEN SAL BETWEEN 1501 AND 3000 THEN 'MID'
  4           WHEN SAL BETWEEN 3001 AND 5000 THEN 'HIGH'
  5         END AS SAL_LEVEL,
  6         COUNT(*) AS EMP_COUNT
  7  FROM EMP
  8  GROUP BY CASE
  9             WHEN SAL BETWEEN 800 AND 1500 THEN 'LOW'
 10             WHEN SAL BETWEEN 1501 AND 3000 THEN 'MID'
 11             WHEN SAL BETWEEN 3001 AND 5000 THEN 'HIGH'
 12           END;

SAL_  EMP_COUNT                                                                                     
