SQL> clear screen
SQL> --display ename ,job and salary with the bonus for the manager 20% ,analyst 15%,clerk 10% rest 5%
SQL> SELECT ENAME,
  2         JOB,
  3         SAL,
  4         CASE
  5             WHEN JOB = 'MANAGER' THEN SAL * 0.20
  6             WHEN JOB = 'ANALYST' THEN SAL * 0.15
  7             WHEN JOB = 'CLERK'   THEN SAL * 0.10
  8             ELSE SAL * 0.05
  9         END AS BONUS
 10  FROM EMP;

