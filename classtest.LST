SQL> SELECT ENAME,
  2         JOB,
  3         SAL,
  4         SAL +
  5         CASE
  6             WHEN JOB = 'MANAGER' THEN SAL * 0.20
  7             WHEN JOB = 'ANALYST' THEN SAL * 0.15
  8             WHEN JOB = 'CLERK'   THEN SAL * 0.10
  9             ELSE SAL * 0.05
 10         END AS TOTAL_SALARY
 11  FROM EMP;

