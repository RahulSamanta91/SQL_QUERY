SQL> SELECT ENAME,
  2         DEPTNO,
  3         CASE
  4             WHEN DEPTNO = 10 THEN 'ACCOUNTING'
  5             WHEN DEPTNO = 20 THEN 'RESEARCH'
  6             WHEN DEPTNO = 30 THEN 'SALES'
  7             ELSE 'OPERATIONS'
  8         END AS DNAME
  9  FROM EMP;

