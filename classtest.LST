SQL> SELECT ENAME,
  2         SAL,
  3         CASE
  4             WHEN SAL >= 5000 THEN 'A'
  5             WHEN SAL >= 3000 THEN 'B'
  6             WHEN SAL >= 1500 THEN 'C'
  7             ELSE 'D'
  8         END AS GRADE
  9  FROM EMP;

