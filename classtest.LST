SQL> SELECT ENAME,
  2         SAL,
  3         HIREDATE,
  4         CASE
  5             WHEN SAL > 4000
  6              AND HIREDATE < '01-JAN-82'
  7             THEN 'ELIGIBLE'
  8             ELSE 'NOT ELIGIBLE'
  9         END AS PROMOTION_STATUS
 10  FROM EMP;

